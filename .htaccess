# Habilitar RewriteEngine
RewriteEngine On

# Redirigir raíz a login.html
RewriteRule ^$ /login.html [L,R=301]
RewriteRule ^index\.html$ /login.html [L,R=301]

# CABECERAS DE SEGURIDAD Y NO-CACHE
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    
    # Forzar que los archivos HTML NUNCA se cacheen en el servidor ni en el navegador
    <FilesMatch "\.(html)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Desactivar Expires para HTML
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# Archivos de Service Worker (SIEMPRE frescos)
<FilesMatch "sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>
